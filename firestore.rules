rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Catch-all default deny
    match /{document=**} {
      allow read, write: if false;
    }
    
    // Global helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isIncomingOwner() {
      return isSignedIn() && request.resource.data.userId == request.auth.uid;
    }
    
    function isExistingOwner() {
      return isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }
    
    match /habits/{habitId} {
      allow create: if isIncomingOwner();
      allow read: if isExistingOwner();
      allow update, delete: if isExistingOwner();
    }
    
    match /habit_logs/{logId} {
      allow create: if isIncomingOwner();
      allow read: if isExistingOwner();
      allow update, delete: if isExistingOwner();
    }
    
    match /weight_logs/{weightId} {
      allow create: if isIncomingOwner();
      allow read: if isExistingOwner();
      allow update, delete: if isExistingOwner();
    }
    
    match /vision_board/{itemId} {
      allow create: if isIncomingOwner();
      allow read: if isExistingOwner();
      allow update, delete: if isExistingOwner();
    }
  }
}
